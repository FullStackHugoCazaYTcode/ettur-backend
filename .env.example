# ETTUR LA UNIVERSIDAD - Variables de Entorno
# Copiar este archivo como .env y editar los valores

# Base de Datos (Railway MySQL)
DB_HOST=your-railway-host.railway.app
DB_PORT=3306
DB_NAME=ettur_recaudacion
DB_USER=root
DB_PASS=your-railway-password

# Aplicación
APP_ENV=production
APP_DEBUG=false

# JWT Secret (cambiar en producción)
JWT_SECRET=tu_clave_secreta_muy_larga_y_segura_2025

# CORS (URL del frontend en Vercel)
CORS_ORIGIN=https://tu-frontend.vercel.app
